// Добавляем HTTP health check в accept_client
static bool is_http_request(const char* data, int len) {
    return (len >= 4 && (strncmp(data, "GET ", 4) == 0 || strncmp(data, "POST", 4) == 0 || strncmp(data, "HEAD", 4) == 0));
}

static void send_http_health_response(socket_t s) {
    std::string response = "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\n\r\nNexus Server OK";
    send(s, response.c_str(), (int)response.size(), 0);
}
