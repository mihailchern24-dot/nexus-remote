#include <windows.h>

LANGUAGE LANG_NEUTRAL, SUBLANG_NEUTRAL
101 DIALOG 0, 0, 280, 120
STYLE DS_CENTER | WS_CAPTION | WS_SYSMENU
CAPTION "Connect to Peer"
FONT 9, "Segoe UI"
{
    LTEXT "Enter Peer ID:", 1001, 15, 15, 80, 12
    EDITTEXT 1002, 15, 30, 250, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON "Connect", IDOK, 100, 70, 70, 24
    PUSHBUTTON "Cancel", IDCANCEL, 180, 70, 70, 24
}
